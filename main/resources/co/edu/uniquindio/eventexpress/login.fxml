<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.uniquindio.eventexpress.controller.LoginController"
            stylesheets="@styles.css">
    <center>
        <VBox alignment="CENTER" spacing="12" maxWidth="360">
            <Label fx:id="lblTitulo" text="EventExpress"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #185FA5;"/>

            <VBox spacing="8">
                <Label text="Correo electrónico"/>
                <TextField fx:id="txtCorreo" promptText="tu@correo.com" styleClass="form-field"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Contraseña"/>
                <PasswordField fx:id="txtContrasena" promptText="••••••••" styleClass="form-field"/>
            </VBox>

            <Button text="Ingresar" onAction="#handleLogin" maxWidth="Infinity"
                    styleClass="btn-primary" defaultButton="true"/>

            <Label fx:id="lblError" style="-fx-text-fill: #E24B4A;"
                   visible="false" managed="false"/>

            <Hyperlink text="¿No tienes cuenta? Regístrate" onAction="#abrirVentanaRegistro"/>

        </VBox>
    </center>
</BorderPane>
